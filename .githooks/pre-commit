#!/usr/bin/env bash
# Pre-commit secret scan with gitleaks.
# Enable once per clone:  git config core.hooksPath .githooks
# Requires gitleaks (brew install gitleaks); skips with a warning if absent so a
# missing install never blocks committing.
set -euo pipefail

if ! command -v gitleaks >/dev/null 2>&1; then
  echo "warning: gitleaks not installed, skipping secret scan (brew install gitleaks)" >&2
  exit 0
fi

gitleaks protect --staged --redact --no-banner
